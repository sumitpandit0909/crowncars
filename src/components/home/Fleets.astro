---
import { Image } from "astro:assets";
import { FaUserFriends, FaCog, FaGasPump, FaPalette } from "react-icons/fa";
import { Fragment } from "react";
import {socials} from "../../lib/config.json";
import { supabase } from "../../lib/supabase";
import { mapSupabaseCarToUI } from "../../lib/carMapper";

// Fetch 3 cars from Supabase
const { data: supabaseCars, error } = await supabase
  .from('cars')
  .select('*')
  .eq('is_available', true)
  .limit(3);

let cars = [];

if (error) {
  console.error("Error fetching cars:", error);
} else if (supabaseCars) {
  cars = supabaseCars.map(mapSupabaseCarToUI);
}
---

<!-- Page Fleets Start -->
<div class="page-fleets">
  <div class="container-fluid">
    <div class="row section-row">
      <div class="col-lg-12">
        <!-- Section Title Start -->
        <div class="section-title">
          <h3 class="wow fadeInUp">our fleets</h3>
          <h2 class="text-anime-style-3" data-cursor="-opaque">
            Explore our perfect and extensive fleet
          </h2>
        </div>
        <!-- Section Title End -->
      </div>
    </div>
    <div class="container" style="display: flex; justify-content: center; flex-direction: column; align-items: center;">
        
            <div class="col-lg-9">
                <div class="fleets-collection-box">
                    <div class="row">
                        {cars.map((car, index) => (
                            <Fragment key={index}>
                                <div class="col-lg-4 col-md-6">
                                    <div class="perfect-fleet-item fleets-collection-item wow fadeInUp">
                                        <!-- Image Slider Start -->
                                        <div class="image-box car-slider" id={`slider-${car.name}`} data-car-name={car.name}>
                                            <div class="slider-images">
                                                {(car.images && car.images.length > 0 ? car.images : ["/assets/images/placeholder-car.jpg"]).map((img, imgIndex) => (
                                                    <div class="slider-image" data-index={imgIndex} style={{display: imgIndex === 0 ? 'block' : 'none'}}>
                                                        <Image src={img} width={800} height={450} alt={`${car.name} image ${imgIndex + 1}`} inferSize={true} />
                                                    </div>
                                                ))}
                                            </div>

                                            {car.images && car.images.length > 1 && (
                                              <>
                                                <!-- Arrow Navigation -->
                                                <div class="slider-arrow prev-arrow">&#10094;</div>
                                                <div class="slider-arrow next-arrow">&#10095;</div>

                                                <div class="slider-nav">
                                                    {car.images.map((_, dotIndex) => (
                                                        <span class={`nav-dot ${dotIndex === 0 ? 'active' : ''}`} data-index={dotIndex}></span>
                                                    ))}
                                                </div>
                                              </>
                                            )}
                                        </div>
                                        <!-- Image Slider End -->

                                        <div class="perfect-fleet-content">
                                            <div class="perfect-fleet-title">
                                                <h3>{car.name} - {car.model}</h3>
                                            </div>

                                            <div class="perfect-fleet-body">
                                                <ul>
                                                    <li><FaUserFriends /> <span>{car.features.seater} seater</span></li>
                                                    <li><FaCog /> <span>{car.features.transmission}</span></li>
                                                    <li><FaGasPump /> <span>{car.features.fuel}</span></li>
                                                    <li><FaPalette /> <span>{car.features.color}</span></li>
                                                </ul>
                                            </div>

                                            <div class="perfect-fleet-footer">
                                                <div class="perfect-fleet-pricing">
                                                    <h2>₹{car.price}<span>/hr</span></h2>
                                                </div>

                                                <div class="perfect-fleet-btn">
                                                    <a href={socials.whatsapp} target="_blank" class="section-icon-btn"><i class="fa-brands fa-whatsapp" style="color: white;font-size: 20px;"></i></a>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </Fragment>
                        ))}
                    </div>
                </div>
            </div>

            <div class="col-lg-12" style="text-align: center; margin-top: 40px;">
                <a href="/cars" class="btn-default">Explore More</a>
            </div>
        </div>
    </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    // Filter functionality
    const transmissionFilters = document.querySelectorAll('.transmission-filter');
    const fuelFilters = document.querySelectorAll('.fuel-filter');
    const carItems = document.querySelectorAll('.fleets-collection-item');

    function filterCars() {
        const selectedTransmissions = Array.from(transmissionFilters)
            .filter(checkbox => checkbox.checked)
            .map(checkbox => checkbox.value);
        
        const selectedFuels = Array.from(fuelFilters)
            .filter(checkbox => checkbox.checked)
            .map(checkbox => checkbox.value);

        carItems.forEach(carItem => {
            const transmission = carItem.querySelector('.perfect-fleet-body li:nth-child(2) span').textContent;
            const fuel = carItem.querySelector('.perfect-fleet-body li:nth-child(3) span').textContent;
            
            const matchesTransmission = selectedTransmissions.length === 0 || selectedTransmissions.includes(transmission);
            const matchesFuel = selectedFuels.length === 0 || selectedFuels.includes(fuel);
            
            if (matchesTransmission && matchesFuel) {
                carItem.closest('.col-lg-4').style.display = '';
            } else {
                carItem.closest('.col-lg-4').style.display = 'none';
            }
        });
    }

    transmissionFilters.forEach(filter => {
        filter.addEventListener('change', filterCars);
    });

    fuelFilters.forEach(filter => {
        filter.addEventListener('change', filterCars);
    });

    // Image slider functionality
    const carSliders = document.querySelectorAll('.car-slider');
    
    // Set up each slider
    carSliders.forEach(slider => {
      const images = slider.querySelectorAll('.slider-image');
      const dots = slider.querySelectorAll('.nav-dot');
      const prevArrow = slider.querySelector('.prev-arrow');
      const nextArrow = slider.querySelector('.next-arrow');
      let currentIndex = 0;
      const totalImages = images.length;

      // Touch swipe variables
      let touchStartX = 0;
      let touchEndX = 0;
      const minSwipeDistance = 50; // Minimum distance for a swipe to be registered
      
      // Function to show image by index
      function showImage(index) {
        // Make sure index is within bounds
        if (index < 0) index = totalImages - 1;
        if (index >= totalImages) index = 0;
        
        // Update current index
        currentIndex = index;
        
        // Hide all images
        images.forEach(img => {
          img.style.display = 'none';
        });
        
        // Show the selected image
        images[currentIndex].style.display = 'block';
        
        // Update active dot
        dots.forEach((dot, i) => {
          dot.classList.toggle('active', i === currentIndex);
        });
      }

         // Touch event handlers
         slider.addEventListener('touchstart', (e) => {
        touchStartX = e.touches[0].clientX;
      }, { passive: true });

      slider.addEventListener('touchmove', (e) => {
        touchEndX = e.touches[0].clientX;
      }, { passive: true });

      slider.addEventListener('touchend', () => {
        const swipeDistance = touchEndX - touchStartX;
        
        if (Math.abs(swipeDistance) > minSwipeDistance) {
          if (swipeDistance > 0) {
            // Swipe right - show previous image
            showImage(currentIndex - 1);
          } else {
            // Swipe left - show next image
            showImage(currentIndex + 1);
          }
        }
      });
      
      // Add click event to each dot
      dots.forEach((dot, dotIndex) => {
        dot.addEventListener('click', () => {
          showImage(dotIndex);
        });
      });
      
      // Add click events to arrows
      prevArrow.addEventListener('click', () => {
        showImage(currentIndex - 1);
      });
      
      nextArrow.addEventListener('click', () => {
        showImage(currentIndex + 1);
      });

      // Auto-sliding functionality
      let slideInterval = null;

      function startSliding() {
        if (slideInterval) return;
        slideInterval = setInterval(() => {
          showImage(currentIndex + 1);
        }, 3000);
      }

      function stopSliding() {
        if (slideInterval) {
          clearInterval(slideInterval);
          slideInterval = null;
        }
      }

      // Start sliding on hover
      slider.addEventListener('mouseenter', startSliding);
      slider.addEventListener('mouseleave', stopSliding);

      // Stop sliding when manually changing slides
      dots.forEach(dot => {
        dot.addEventListener('click', stopSliding);
      });
      
      prevArrow.addEventListener('click', stopSliding);
      nextArrow.addEventListener('click', stopSliding);
    });
  });
</script>

<style>
  .car-slider {
    position: relative;
    overflow: hidden;
    border-radius: 10px;
    width: 100%;
    /* aspect-ratio: 16/9; */
    display: block;
  }

  .slider-images {
    width: 100%;
    position: relative;
    display: block;
  }

  .slider-image {
    width: 100%;
  }
  .slider-image img {
    width: 100%;
    /* height: 100px; */
    object-fit: cover;
    border-radius: 10px;
    display: block;
    max-width: 100%;
  }

  .slider-image img {
    width: 100%;
    height: 170px;
    object-fit: cover;
    border-radius: 10px;
  }

  .slider-nav {
    position: absolute;
    bottom: 10px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 8px;
    z-index: 10;
  }

  .nav-dot {
    display: block;
    width: 10px;
    height: 10px;
    background: rgba(255, 255, 255, 0.7);
    border-radius: 50%;
    cursor: pointer;
    transition: background 0.3s;
  }

  .nav-dot.active {
    background: #333;
  }

  /* Arrow Navigation Styles */
  .slider-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 30px;
    height: 30px;
    background-color: rgba(255, 255, 255, 0.7);
    color: #333;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 10;
    font-size: 18px;
    font-weight: bold;
    transition: background-color 0.3s, color 0.3s;
  }

  .slider-arrow:hover {
    background-color: rgba(0, 0, 0, 0.7);
    color: white;
  }

  .prev-arrow {
    left: 10px;
  }

  .next-arrow {
    right: 10px;
  }
</style>