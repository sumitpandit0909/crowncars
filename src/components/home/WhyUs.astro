---
import { Image } from "astro:assets";
import choose1 from "../../assets/images/icon-why-choose-1.svg";
import choose2 from "../../assets/images/icon-why-choose-2.svg";
import choose3 from "../../assets/images/icon-why-choose-3.svg";
import choose4 from "../../assets/images/icon-why-choose-4.svg";
import choose from "../../assets/images/why-choose-img.jpg";
---

<!-- Why Choose Us Section Start -->
<div class="why-choose-us">
  <div class="container">
    <div class="row section-row">
      <div class="col-lg-12">
        <!-- Section Title Start -->
        <div class="section-title">
          <h3 class="wow fadeInUp">why choose us</h3>
          <h2 class="text-anime-style-3" data-cursor="-opaque">
            Unmatched quality and service for your needs
          </h2>
        </div>
        <!-- Section Title End -->
      </div>
    </div>

    <div class="row align-items-center">
      <div class="col-lg-4 col-md-6 order-lg-1 order-md-1 order-1">
        <!-- Why Choose Item Start -->
        <div class="why-choose-item wow fadeInUp">
          <div class="icon-box">
            <Image src={choose1} alt="" />
          </div>
          <div class="why-choose-content">
            <h3>extensive fleet options</h3>
            <p>
              A wide selection of vehicles to match different travel needs, styles, and budgets.
            </p>
          </div>
        </div>
        <!-- Why Choose Item End -->

        <!-- Why Choose Item Start -->
        <div class="why-choose-item wow fadeInUp" data-wow-delay="0.25s">
          <div class="icon-box">
            <Image src={choose2} alt="" />
          </div>
          <div class="why-choose-content">
            <h3>exceptional customer service</h3>
            <p>
              Friendly and responsive support to ensure a smooth and hassle-free experience.
            </p>
          </div>
        </div>
        <!-- Why Choose Item End -->
      </div>

      <div class="col-lg-4 col-md-12 order-lg-2 order-md-3 order-2">
        <div class="why-choose-image">
          <figure class="reveal">
            <Image src={choose} alt="" />
          </figure>
        </div>
      </div>

      <div class="col-lg-4 col-md-6 order-lg-3 order-md-2 order-3">
        <!-- Why Choose Item Start -->
        <div class="why-choose-item wow fadeInUp">
          <div class="icon-box">
            <Image src={choose3} alt="" />
          </div>
          <div class="why-choose-content">
            <h3>convenient locations</h3>
            <p>
              Multiple easy-to-reach pickup and drop-off locations for your convenience.
            </p>
          </div>
        </div>
        <!-- Why Choose Item End -->

        <!-- Why Choose Item Start -->
        <div class="why-choose-item wow fadeInUp" data-wow-delay="0.25s">
          <div class="icon-box">
            <Image src={choose4} alt="" />
          </div>
          <div class="why-choose-content">
            <h3>reliability and safety</h3>
            <p>
              Well-maintained vehicles with safety checks to ensure dependable journeys.
            </p>
          </div>
        </div>
        <!-- Why Choose Item End -->
      </div>
    </div>
  </div>
</div>
<!-- Why Choose Us Section End -->
