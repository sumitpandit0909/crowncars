---
import ContactCard from "../components/contact/ContactCard.astro";
import GeneralHero from "../components/global/GeneralHero.astro";
import Layout from "../layouts/Layout.astro";
import {seo,brand} from "../lib/config.json"
---

<Layout title={seo.contactus.title} description={seo.contactus.description}>
  <GeneralHero title="Contact Us" />
  <ContactCard />
  <!-- Google Map Start -->
  <div class="google-map">
    <div class="container">
      <div class="row section-row">
        <div class="col-lg-12">
          <!-- Section Title Start -->
          <div class="section-title">
            <h3 class="wow fadeInUp">location</h3>
            <h2 class="text-anime-style-3" data-cursor="-opaque">
              How to reach our location
            </h2>
          </div>
          <!-- Section Title End -->
        </div>
      </div>
      <div class="row">
        <div class="col-lg-12">
          <!-- Google Map Iframe Start -->
          <div class="google-map-iframe">
            <iframe
              src={brand.map}
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"></iframe>
              <iframe src={brand.map}  allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
          </div>
          <!-- Google Map Iframe End -->
        </div>
      </div>
    </div>
  </div>
  <!-- Google Map End -->
</Layout>
