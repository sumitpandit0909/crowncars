---
import GeneralHero from "../components/global/GeneralHero.astro";
import Layout from "../layouts/Layout.astro";
import {seo} from "../lib/config.json";
import { marked } from "marked";
import { fetchLegalPage } from "../lib/legal";
import { Fragment } from "react";

const privacyData = await fetchLegalPage('privacy');

---

<Layout title={seo.privacy.title} description={seo.privacy.description}>
    <GeneralHero title="Privacy Policy" />

    <section class="terms-container m-5">
        <div class="container">
            {privacyData ? (
                <Fragment>
                    <div class="content-box" set:html={marked.parse(privacyData.content_mdx)} />
                    <p class="mt-4 text-sm text-gray-500">Last updated: {new Date(privacyData.updated_at).toLocaleDateString()}</p>
                </Fragment>
            ) : (
                <div class="error-box">
                    <h2>Privacy Policy</h2>
                    <p>Unable to load privacy policy at this time. Please try again later.</p>
                </div>
            )}
        </div>
    </section>
</Layout>
