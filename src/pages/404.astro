---
import Layout from "../layouts/Layout.astro";
import { socials } from "../lib/config.json";

// The Play Store link for Crown Cars
const playStoreUrl = "https://play.google.com/store/apps/details?id=com.crowncars.app";
---

<Layout title="Page Not Found - Redirecting to Play Store" description="The page you are looking for does not exist. Redirecting to the Crown Cars app on Play Store.">
  <div class="error-page">
    <div class="container">
      <div class="row justify-content-center">
        <div class="col-lg-8">
          <div class="error-content wow fadeInUp">
            <div class="app-promo-box">
              <h3>Get the Full Experience</h3>
              <p>This page is only available on the Crown Cars app.</p>
              <p>Download the <strong>Crown Cars</strong> app from the Play Store for easier bookings and exclusive features.</p>
              
              <div class="redirect-timer">
                Redirecting to Play Store in <span id="countdown">3</span> seconds...
              </div>

              <div class="error-btn">
                <a href={playStoreUrl} class="btn-default">Download App Now</a>
                <!-- <a href="/" class="btn-default btn-highlighted">Go Back Home</a> -->
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script is:inline define:vars={{ playStoreUrl }}>
    let seconds = 3;
    const countdownEl = document.getElementById('countdown');

    const interval = setInterval(() => {
      seconds--;
      if (countdownEl) countdownEl.textContent = seconds;
      if (seconds <= 0) {
        clearInterval(interval);
        window.location.href = playStoreUrl;
      }
    }, 1000);
  </script>

  <style>
    .error-page {
      padding: 150px 0;
      background-color: var(--primary-color);
      min-height: 80vh;
      display: flex;
      align-items: center;
      text-align: center;
    }
    
    .error-code {
      font-size: clamp(80px, 15vw, 180px);
      font-weight: 900;
      line-height: 1;
      color: var(--accent-color);
      font-family: var(--accent-font);
      margin-bottom: 20px;
      opacity: 0.8;
    }

    .error-content h1 {
      font-size: clamp(24px, 5vw, 48px);
      margin-bottom: 20px;
      color: var(--white-color);
    }

    .error-content p {
      font-size: 18px;
      color: var(--text-color);
      max-width: 600px;
      margin: 0 auto 30px;
    }

    .app-promo-box {
      background: var(--secondary-color);
      padding: 60px 40px;
      border-radius: 40px;
      border: 1px solid var(--accent-color);
      /* margin-top: 50px; */
      box-shadow: 0 15px 40px rgba(255, 54, 0, 0.15);
      transform: scale(1.05);
    }

    .app-promo-box h3 {
      font-size: 32px;
      margin-bottom: 20px;
      color: var(--accent-color);
      font-family: var(--accent-font);
    }

    .redirect-timer {
      font-size: 20px;
      font-weight: 600;
      margin: 30px 0;
      color: var(--white-color);
      background: rgba(255, 54, 0, 0.15);
      padding: 12px 30px;
      border-radius: 50px;
      display: inline-block;
      border: 1px solid rgba(255, 54, 0, 0.3);
    }

    .error-btn {
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
      gap: 20px;
      margin-top: 20px;
    }

    .btn-default {
      margin-right: 0 !important; /* Override theme margin */
    }

    #countdown {
      color: var(--accent-color);
      font-size: 22px;
      font-weight: 800;
    }

    @media (max-width: 767px) {
      .error-page {
        padding: 100px 0;
      }
      .app-promo-box {
        padding: 25px;
      }
      .error-btn {
        flex-direction: column;
        align-items: center;
      }
    }
  </style>
</Layout>
